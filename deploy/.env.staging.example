# Staging Environment Configuration
# SeedCamp AI Video Generation Pipeline

# ==========================================
# BytePlus ModelArk API Configuration
# ==========================================
ARK_API_KEY=your-staging-api-key-here
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ==========================================
# Model Configuration
# ==========================================
SCRIPT_MODEL=seed-1-8-251228
VIDEO_MODEL_PRO=dreamina-seedance-2-0-260128
VIDEO_MODEL_FAST=dreamina-seedance-2-0-fast-260128

# ==========================================
# Timeouts & Polling
# ==========================================
POLL_TIMEOUT=300
POLL_INTERVAL=5

# ==========================================
# Storage
# ==========================================
OUTPUT_DIR=./output

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ==========================================
# CORS (API)
# ==========================================
CORS_ORIGINS=http://localhost:8501,https://staging.yourdomain.com

# ==========================================
# Rate Limiting (slowapi format)
# ==========================================
RATE_LIMIT=50/minute
